{
  "name": "nuigurumi_agent_2",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "build:web": "node ./scripts/clean-next.js && next build",
    "export:web": "node ./scripts/clean-next.js && next build",
    "electron:dev": "npm run build:web && electron .",
    "electron:build": "npm run build:web && electron-builder",
    "electron:rebuild": "electron-rebuild -f -w @supabase/supabase-js"
  },
  "main": "electron/main.js",
  "dependencies": {
    "@supabase/supabase-js": "^2.104.0",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "openai": "^6.34.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "electron": "^26.0.0",
    "electron-builder": "^24.8.0",
    "dotenv": "^16.0.0",
    "electron-rebuild": "^3.2.9"
  }
  ,
  "build": {
    "appId": "com.example.nuigurumi",
    "productName": "Nuigurumi Agent",
    "files": [
      "out/**/*",
      "electron/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "arch": ["armv7l", "arm64", "x64"]
    }
  }
}
